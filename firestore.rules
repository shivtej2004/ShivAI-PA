rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global Safety Net: Deny all reads and writes by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Reusable global security helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // User State entity validation helper (Pillar 2: Anti-Update-Gap)
    function isValidUserState(data) {
      return data.keys().hasAll(['uid']) && 
             data.keys().size() <= 15 && 
             data.uid is string && 
             data.uid == request.auth.uid;
    }

    // User state collection match block
    match /user_states/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create, update: if isOwner(userId) && isValidUserState(request.resource.data) && isValidId(userId);
      allow delete: if isOwner(userId) && isValidId(userId);
    }
  }
}
